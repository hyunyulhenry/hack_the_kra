# ============================================
# KRA 경마 예측 시스템 — API 키 관리
# 이 파일을 .env로 복사한 후 키 입력
# ============================================

# --- Phase 1: 역사 데이터 수집 ---
KEY_AI_RACE_RESULT_DETAIL=        # AI기반연구용_경주결과상세 (15150068)
KEY_AI_RACE_RESULT=               # AI학습용_경주결과 (15143803)
KEY_AI_RACE_PLAN=                 # AI학습용_경주계획 (15143802)
KEY_CONFIRMED_ODDS=               # 확정배당율 통합 정보 (15058559)
KEY_SALES_AND_ODDS=               # 경마 매출액 및 확정배당율 (15057896)
KEY_HORSE_RATING=                 # 경주마 레이팅 정보 (15057323)
KEY_JOCKEY_1YEAR=                 # 기수최근1년성적비교
KEY_TRAINER_INFO=                 # 조교사 상세정보
KEY_RACE_RECORD=                  # 경주기록 정보 (15058305)
KEY_RACE_RESULT=                  # 경주성적정보 (15063979)
KEY_HORSE_RESULT=                 # 경주마 성적 정보 (15058779)
KEY_RACE_DETAIL_SCORE=            # 경주별상세성적표 (15089492)
KEY_RACE_INFO=                    # 경마경주정보 (15063951)
KEY_RC_RACE_INFO=                 # RC경마경주정보 (15063950)

# --- Phase 2: 당일 실시간 ---
KEY_HORSE_WEIGHT=                 # 출전마 체중 정보
KEY_JOCKEY_CHANGE=                # 기수변경 정보 (15057181)
KEY_ENTRY_DETAIL=                 # 출전표 상세정보 (15058677)
KEY_SANCTION=                     # 제재내역 (15037098)
KEY_DAILY_RESULT=                 # 경마시행당일_경주결과종합 (15119524)
KEY_DAILY_ODDS=                   # 경마시행당일_확정배당율종합 (15119558)
KEY_DAILY_JOCKEY_CHANGE=          # 경마시행당일_기수변경상세

# --- Phase 3: 피처 심화 ---
KEY_SECTIONAL_RECORD=             # 마필 구간별 경주기록 (15057859)
KEY_CORNER_RANKING=               # 경마코너별통과순위_주로빠르기
KEY_TRAINER_DAILY=                # 조교사일일조교일자 (15089712)
KEY_JOCKEY_STATS=                 # 기수 성적 정보 (15056591)
KEY_BLOODLINE=                    # 혈통정보기본 (15109000)
KEY_FOREIGN_RESULT=               # 해외경주성적정보
KEY_HORSE_DETAIL=                 # 경주마 상세정보 (15058115)
KEY_DAILY_TRAINING=               # 일별훈련 상세정보 (15058782)
KEY_GRADE_CHANGE=                 # 경주마 등급변동내역 (15058076)
KEY_MEDICAL=                      # 경주마 경주전 1년간 진료내역
